{
  "expo": {
    "name": "SmartTour",
    "slug": "smart-tourism-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smarttour.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0077B6"
      },
      "package": "com.smarttour.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0077B6",
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
